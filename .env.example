# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
# Get from: Atlas dashboard → your cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/campusfinder?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────────────────
# Any long random string (used to sign JWTs)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex

# ── Groq (AI enrichment + NL search) ─────────────────────────────────────────
# Get from: console.groq.com → API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cloudinary (image storage) ────────────────────────────────────────────────
# Get from: cloudinary.com → Dashboard → Product Environment Credentials
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email — Brevo SMTP (transactional mail) ───────────────────────────────────
# Sign up at brevo.com (free — 300 emails/day)
# Get SMTP credentials from: Brevo dashboard → Settings → SMTP & API → SMTP tab
#
# BREVO_SMTP_USER  → your Brevo account login email (e.g. you@gmail.com)
# BREVO_SMTP_PASS  → the SMTP key shown in Brevo (NOT your Brevo password)
# MAIL_FROM        → the "From" address shown in emails
#                    Use any address — ideally a domain you own, or your Brevo sender
#                    Example: CampusFinder <noreply@yourdomain.com>
#                    Or just:  CampusFinder <you@gmail.com>  (if verified in Brevo)
#
BREVO_SMTP_USER=your_brevo_login@example.com
BREVO_SMTP_PASS=xsmtpsib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxx
MAIL_FROM=CampusFinder <noreply@yourdomain.com>

# ── Admin ─────────────────────────────────────────────────────────────────────
# Password to access the /admin panel
ADMIN_PASSWORD=choose_a_strong_password

# ── URLs ──────────────────────────────────────────────────────────────────────
# Frontend URL (used in email links and CORS)
# Production example: https://campusfinder.vercel.app
CLIENT_URL=http://localhost:3000
