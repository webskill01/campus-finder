{
  "name": "campusfinder",
  "version": "1.0.0",
  "description": "Dark-themed campus lost & found MERN SPA with AI matching engine",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"nodemon server/index.js\" \"npm run client\"",
    "client": "node node_modules/vite/bin/vite.js client --port 3000",
    "build": "node node_modules/vite/bin/vite.js build client",
    "start": "node server/index.js"
  },
  "keywords": [
    "lost-and-found",
    "campus",
    "ai-matching",
    "mern"
  ],
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "colorthief": "^3.3.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "groq-sdk": "^0.7.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.454.0",
    "mongoose": "^8.7.0",
    "multer": "^1.4.5-lts.1",
    "natural": "^8.1.1",
    "node-cron": "^3.0.3",
    "nsfwjs": "^4.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "nodemon": "^3.1.7",
    "vite": "^5.4.10"
  }
}
